# Copy this file to `.env` and fill in your real key.
# `.env` is gitignored so secrets do not leak.

# ---------- Required ----------

# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ---------- Optional model overrides ----------

# Defaults (set in pawpal/llm_client.py) are usually fine.
# Switch to gpt-4o for higher accuracy at ~17x the cost.
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ---------- Optional safety / debug switches ----------

# Set to 1 to bypass the self-critique layer (Phase 3).
# When set, RAG/Agent traces still record a *mock* CriticReport
# (level="medium", confidence=0.65) but no LLM call is made.
# Useful as an emergency rollback if the critic regresses or
# while debugging without burning tokens.
# PAWPAL_DISABLE_CRITIC=
